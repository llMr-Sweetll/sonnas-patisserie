# --- Database (Supabase Postgres) ---
# Use the SESSION pooler (port 5432) — transaction mode (6543) breaks sqlx's
# prepared statements. Any Postgres role with login works; production uses a
# dedicated `sonnas_app` role rather than `postgres`.
DATABASE_URL=postgres://sonnas_app.<project-ref>:<password>@aws-1-ap-south-1.pooler.supabase.com:5432/postgres?sslmode=require

# --- Supabase Storage (product image uploads from admin) ---
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# --- App secrets ---
# 32+ random bytes, hex/base64, used to sign session + CSRF cookies:
#   openssl rand -hex 32
SESSION_SECRET=
# Generate with: cargo run --bin hash-password -- 'your-admin-password'
ADMIN_PASSWORD_HASH=

# --- Razorpay ---
RAZORPAY_KEY_ID=rzp_test_xxxxxxxx
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# --- WhatsApp (Meta Cloud API) ---
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
# Webhook verification + signature checking (from the Meta app dashboard)
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=
# Owner's number for order alerts + the wa.me button, E.164 without '+', e.g. 919113231424
OWNER_WHATSAPP_NUMBER=919113231424

# --- Claude (WhatsApp bot free-text understanding) ---
ANTHROPIC_API_KEY=

# --- Server ---
PORT=3000
# Set to the public URL in production (used in payment links / callbacks)
BASE_URL=http://localhost:3000

# Daily birthday-reminder cron (Vercel sends this as a Bearer token)
# openssl rand -hex 24
CRON_SECRET=
